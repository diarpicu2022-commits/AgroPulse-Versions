# AgroPulse Environment Variables
# ⚠️ IMPORTANTE: Copia este archivo a .env y rellena tus credenciales reales
# ⛔ NUNCA subas .env a GitHub (está en .gitignore para proteger credenciales)
# 🔒 Los archivos .env.local y .env.*.local tampoco se suben

# 🔌 Supabase PostgreSQL (Backend Java/Spring)
# Obtener: https://supabase.com → Settings → Database → Connection String
# Seleccionar: JDBC - Session pooler (puerto 6543)
# Formato: jdbc:postgresql://[USER]:[PASSWORD]@[HOST]:6543/postgres?sslmode=require
SUPABASE_JDBC_URL=jdbc:postgresql://postgres.XXXXXXX:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# 🌐 Backend REST API (Frontend se conecta aquí)
VITE_API_URL=http://localhost:8080

# 🔐 Supabase Frontend (Google OAuth + Real-time)
# Obtener de: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://[PROJECT_ID].supabase.co
VITE_SUPABASE_ANON_KEY=[YOUR_ANON_KEY]

# 🤖 AI Services (Opcionales)
GROQ_API_KEY=gsk_XXXXXXX
GITHUB_TOKEN=ghp_XXXXXXX
OPENAI_API_KEY=sk-XXXXXXX
OPENROUTER_API_KEY=sk-or-v1-XXXXXXX
DEEPSEEK_API_KEY=sk-XXXXXXX

# 📱 WhatsApp Integration (Opcional - Green API)
GREEN_ID_INSTANCE=
GREEN_API_TOKEN=
GREEN_API_URL=https://1234.api.greenapi.com
ALERT_PHONE=+[TU_NUMERO]

# 🤖 Ollama Local (Opcional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2
MISTRAL_KEY=

# 🔑 Google OAuth (Solo si usas autenticación local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

