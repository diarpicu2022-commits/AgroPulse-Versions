# AgroPulse Environment Variables
# Copia este archivo a .env y rellena tus credenciales reales
# NUNCA subas .env a Git (está en .gitignore)

# 🔌 Supabase JDBC Connection String
# Obtener de: Supabase → Settings → Database → Connection String (JDBC, Session pooler)
# Formato: jdbc:postgresql://postgres:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres?sslmode=require
SUPABASE_JDBC_URL=jdbc:postgresql://postgres:TU_PASSWORD@db.lujulcpskvwpijpjpahk.supabase.co:5432/postgres?sslmode=require

# Frontend API URL
VITE_API_URL=http://localhost:8080

# IA Keys (opcionales)
VITE_GROQ_KEY=your_groq_key_here
VITE_GITHUB_TOKEN=your_github_token_here
VITE_OLLAMA_HOST=http://localhost:11434

# Supabase Frontend (opcional - solo si usas Supabase desde React)
VITE_SUPABASE_URL=https://lujulcpskvwpijpjpahk.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
