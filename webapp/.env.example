# AgroPulse Frontend — Environment Variables
# ⚠️ PLANTILLA: Copia a .env.local y completa con tus credenciales
# ⛔ NUNCA SUBIR .env.local A GITHUB (contiene claves sensibles)
# 📝 Los archivos en .gitignore protegen: .env, .env.local, .env.*.local

# 🌐 Backend REST API (donde está tu servidor Java en puerto 8080)
# El frontend consulta aquí para CRUD de sensores, actuadores, reglas, etc.
VITE_API_URL=http://localhost:8080

# 🔐 Supabase (Google OAuth + Real-time Database)
# Obtener de: https://supabase.com → Settings → API
# URL: Copiar "Project URL"
# ANON KEY: Copiar "anon public" key
VITE_SUPABASE_URL=https://[PROJECT_ID].supabase.co
VITE_SUPABASE_ANON_KEY=[YOUR_ANON_KEY]

# 🤖 AI Services (Opcionales - para chat IA en el frontend)
# Solo si quieres habilitar respuestas de IA en el dashboard
VITE_GROQ_KEY=gsk_XXXXXXX
VITE_GITHUB_TOKEN=ghp_XXXXXXX
VITE_OPENAI_API_KEY=sk-XXXXXXX
VITE_OPENROUTER_KEY=sk-or-v1-XXXXXXX

# 🤖 Ollama Local (Opcional)
VITE_OLLAMA_HOST=http://localhost:11434

